---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, getLocaleFromUrl, getDateLocale } from '../i18n/utils';

interface Props {
  title: string;
  pubDate: Date;
  tags?: string[];
  collection: 'reviews' | 'projects' | 'travel';
  author?: string;
  publicationYear?: number;
}

const { title, pubDate, tags, collection, author, publicationYear } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);

const formattedDate = pubDate.toLocaleDateString(getDateLocale(locale), {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const collectionKey = `collection.${collection}` as keyof typeof import('../i18n/ui').ui['en'];
const collectionLabel = t(locale, collectionKey);
---

<BaseLayout title={`${title} - ${collectionLabel}`}>
  <Header slot="header" />
  
  <article class="prose prose-lg max-w-none article-post">
    <header class="header-container">
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      
      {author && publicationYear && (
        <p class="author-info">
          {t(locale, 'content.by')} {author} ({publicationYear})
        </p>
      )}
      
      <div class="flex items-center gap-4 date-container">
        <time datetime={pubDate.toISOString()} class="post-date">
          {formattedDate}
        </time>
      </div>

      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <a 
              href={`/${collection}/tag/${tag}`}
              class="post-tag"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose-content">
      <slot />
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .header-container {
    max-width: 800px;
    margin: 0 auto var(--spacing-1) auto;
    background-color: var(--color-bg-content);
    color: var(--color-text-on-dark);
    padding: var(--spacing-6);
    border-radius: var(--radius-lg);
  }

  .header-container h1 {
    margin-bottom: var(--spacing-2);
  }

  .author-info {
    color: var(--color-text-on-dark);
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-1);
  }

  .post-date {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .date-container {
    margin-bottom: var(--spacing-3);
  }

  .post-tag {
    font-size: var(--font-size-xs);
    color: var(--color-interactive);
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-interactive);
    text-decoration: none;
    display: inline-block;
    transition: var(--transition-colors);
    transition-delay: var(--transition-delay-none);
  }

  .post-tag:hover {
    background-color: var(--color-interactive);
    color: var(--color-text-on-dark);
    text-decoration: none;
  }

  .post-tag:focus-visible {
    outline: 2px solid var(--color-interactive);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
    transition-delay: var(--transition-delay-none);
  }

  @media (max-width: 768px) {
    .header-container {
      border-radius: 0;
      padding: var(--spacing-4);
    }
  }
</style>
