---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import QuoteBanner from '../../components/QuoteBanner.astro';
import ContentListItem from '../../components/ContentListItem.astro';
import { t, getLocaleFromUrl } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const allReviews = await getCollection('reviews', ({ data }) => {
  return data.draft === false;
});

const sortedReviews = allReviews.sort((a, b) => {
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout 
  title={t(locale, 'reviews.title')}
  description={t(locale, 'reviews.description')}
>
  <Header slot="header" />
  
  <section class="section">
    <QuoteBanner />
  </section>

  <div class="main-container">
    <section class="section">
      <p class="page-intro">
        {t(locale, 'reviews.intro')}
      </p>

      <p class="page-intro">
        {t(locale, 'reviews.intro2.prefix')} <a href="https://docs.google.com/spreadsheets/d/1KBcC6kPlFMojaJ0qsyxlT6AmEO_JHay75Rf9d5mzLcY/edit?usp=sharing" target="_blank" rel="noopener noreferrer">{t(locale, 'reviews.intro2.sheet')}</a> {t(locale, 'reviews.intro2.or')} <a href="https://www.goodreads.com/user/show/94888357-harsh" target="_blank" rel="noopener noreferrer">Goodreads</a> {t(locale, 'reviews.intro2.account')}
      </p>

    </section>

    <section class="section">
      <div class="mb-8">
        <div class="flex justify-between items-center mb-8">
          <p class="count-display">
            {sortedReviews.length} {sortedReviews.length === 1 ? t(locale, 'reviews.countSingular') : t(locale, 'reviews.countPlural')}
          </p>
          
          <div class="flex gap-2 items-center">
            <select id="sort-select" class="sort-dropdown">
              <option value="title" selected>{t(locale, 'sort.title')}</option>
              <option value="author">{t(locale, 'sort.author')}</option>
              <option value="year">{t(locale, 'sort.year')}</option>
            </select>
          </div>
        </div>
      </div>

      <ul id="reviews-list" class="content-list space-y-4">
        {sortedReviews.map(book => (
          <ContentListItem
            title={book.data.title}
            slug={book.slug}
            collection="reviews"
            metadata={`${t(locale, 'content.by')} ${book.data.author} (${book.data.publicationYear})`}
            sortData={{
              title: book.data.title,
              author: book.data.author,
              year: book.data.publicationYear
            }}
          />
        ))}
      </ul>

      {sortedReviews.length === 0 && (
        <div class="text-center py-12">
          <p class="empty-message">{t(locale, 'reviews.empty')}</p>
        </div>
      )}
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script is:inline>
  function sortReading(sortBy) {
    const list = document.getElementById('reviews-list');
    if (!list) {
      console.error('reviews-list not found');
      return;
    }

    const items = Array.from(list.querySelectorAll('.content-item'));
    
    items.sort((a, b) => {
      const aValue = a.getAttribute('data-' + sortBy) || '';
      const bValue = b.getAttribute('data-' + sortBy) || '';
      
      if (sortBy === 'year') {
        return parseInt(aValue) - parseInt(bValue);
      }
      return aValue.localeCompare(bValue);
    });

    items.forEach(item => list.appendChild(item));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSorting);
  } else {
    initSorting();
  }

  function initSorting() {
    const sortSelect = document.getElementById('sort-select');
    if (sortSelect) {
      sortSelect.addEventListener('change', (e) => sortReading(e.target.value));
    }
  }
</script>
